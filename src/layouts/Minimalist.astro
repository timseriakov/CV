---
import "@fontsource/open-sans";
import Download from "../components/Download.astro";
import "../styles.css";

type Props = {
  frontmatter: {
    title: string;
    pdfLink: string;
    noIndex?: boolean;
    description?: string;
  };
};

const { PDF_VIEW, FORCE_THEME = "" } = import.meta.env;
const IS_PDF_VIEW = PDF_VIEW || Astro.url.searchParams.has("pdf");

const { title, pdfLink, noIndex, description } = Astro.props
  .frontmatter as Props["frontmatter"];

---

<!doctype html>
<html lang="en" class={FORCE_THEME}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description || title} />
    {noIndex && <meta name="robots" content="noindex" />}
    <title>{title}</title>
  </head>
  <body class={!IS_PDF_VIEW ? "bg-indigo-50 text-slate-800 antialiased dark:bg-[#2b292d] sm:my-14" : "pdf-view bg-white text-slate-800 antialiased"}>
    <div class={IS_PDF_VIEW ? "mx-auto flex justify-center" : "container mx-auto flex justify-center px-4 sm:px-6"}>
      <article class="minimalist relative">
        {
          !IS_PDF_VIEW && (
            <div class="download-control not-prose absolute right-4 top-4">
              <Download href={pdfLink} />
            </div>
          )
        }
        <slot />
      </article>
    </div>
    <style></style>
  </body>
</html>
